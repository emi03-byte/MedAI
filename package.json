    "test:e2e:report": "playwright show-report",
    "deploy:package-backend": "powershell -ExecutionPolicy Bypass -File ./deploy/package-backend.ps1",
    "deploy:build-frontend": "powershell -ExecutionPolicy Bypass -File ./deploy/build-frontend.ps1",
    "deploy:manual": "powershell -ExecutionPolicy Bypass -File ./deploy/manual-deploy.ps1"
  },
  "dependencies": {
